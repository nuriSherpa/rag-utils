{
  "name": "rag-utils",
  "version": "0.1.0",
  "description": "Local-first RAG that indexes your codebase down to the function level, and feeds relevant code into your AI chat tabs via a Chrome extension.",
  "type": "module",
  "main": "dist/bin/rag.js",
  "bin": {
    "rag": "./dist/bin/rag.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch bin/rag.ts",
    "start": "node dist/bin/rag.js",
    "rag": "tsx bin/rag.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"bin/**/*.ts\"",
    "test": "vitest run"
  },
  "keywords": [
    "rag",
    "embeddings",
    "code-search",
    "cli",
    "chrome-extension",
    "developer-tools"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.3.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "ignore": "^5.3.1",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-typescript": "^0.21.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "eslint": "^9.7.0",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  }
}
